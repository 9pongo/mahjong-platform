# ── Supabase ──────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT ───────────────────────────────
JWT_SECRET=your-secret-key-change-me

# ── 伺服器 ──────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ── SMS（開發環境 mock，正式用 Twilio）──
SMS_PROVIDER=mock
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── ECPay 金流（不填 = Mock 模式自動到帳）──
# ECPAY_MERCHANT_ID=
# ECPAY_HASH_KEY=
# ECPAY_HASH_IV=
# ECPAY_SANDBOX=true
# ECPAY_RETURN_URL=https://你的網域/api/shop/callback
# ECPAY_ORDER_RESULT_URL=https://你的網域/pages/shop.html?result=1

# ── 管理後台 ──────────────────────────────
ADMIN_KEY=your-admin-secret-key

# ── 告警推播（不填=只記 log）────────────────
# Discord: Server Settings → Integrations → Webhooks → 複製 URL
DISCORD_WEBHOOK_URL=
# LINE Notify: https://notify-bot.line.me/my/ 取得 Token
LINE_NOTIFY_TOKEN=
