{
  "name": "mahjong-platform",
  "version": "1.0.0",
  "description": "台灣麻將多人連線平台",
  "main": "server/index.js",
  "scripts": {
    "start":          "node server/index.js",
    "dev":            "node scripts/check-env.js && nodemon server/index.js",
    "test":           "node tests/mahjongEngine.test.js",
    "test:rules":     "node tests/mahjongRules.test.js",
    "test:validate":  "node tests/validate.test.js",
    "test:rank":      "node tests/rankService.test.js",
    "test:all":       "node tests/mahjongRules.test.js && node tests/validate.test.js && node tests/rankService.test.js && node tests/mahjongEngine.test.js",
    "check-env":      "node scripts/check-env.js",
    "smoke":          "node scripts/smoke-test.js",
    "smoke:prod":     "node scripts/smoke-test.js $RAILWAY_URL",
    "alert:test":     "node scripts/alert-webhook.js $RAILWAY_URL $ADMIN_KEY"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
